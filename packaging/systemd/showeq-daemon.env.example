# Per-host configuration for the showeq-daemon systemd unit.
# Copy to /etc/showeq-daemon/showeq-daemon.env and edit.

# Network device to capture on. Find with `ip link`. Required for live
# capture; replay-only deployments can leave it blank and pass --replay
# via SEQ_EXTRA_ARGS, but that's an unusual setup for a service.
SEQ_DEVICE=eth0

# Address:port the daemon serves WebSocket clients on. 0.0.0.0 binds
# all interfaces (LAN-reachable); 127.0.0.1 keeps it loopback-only.
SEQ_LISTEN=0.0.0.0:9090

# Anything else: --maps-dir, --record-vpk, --record-golden,
# --config-dir, etc. Quote the whole thing if it contains spaces.
#
# Note: opcode XML / spells_us.txt / eqstr_us.txt are read from the
# compiled-in PKGDATADIR (default /usr/local/share/showeq-daemon) and
# the daemon's writable user dir is $HOME/.showeq — set User= in the
# unit to your account so $HOME resolves correctly and writes coexist
# with legacy showeq. --config-dir is only needed here if you want to
# point at a non-installed conf/ tree (e.g. a build dir).
SEQ_EXTRA_ARGS=
