# Per-host configuration for the showeq-daemon systemd unit.
# Copy to /etc/showeq-daemon/showeq-daemon.env and edit.

# Network device to capture on. Find with `ip link`. Required for live
# capture; replay-only deployments can leave it blank and pass --replay
# via SEQ_EXTRA_ARGS, but that's an unusual setup for a service.
SEQ_DEVICE=eth0

# Address:port the daemon serves WebSocket clients on. 0.0.0.0 binds
# all interfaces (LAN-reachable); 127.0.0.1 keeps it loopback-only.
SEQ_LISTEN=0.0.0.0:9090

# Directory holding opcode XML, seqdef.xml, etc. Defaults to
# /usr/local/share/showeq-daemon if you `cmake --install` from a
# default-prefix build.
SEQ_CONFIG_DIR=/usr/local/share/showeq-daemon

# Anything else: --maps-dir, --record-vpk, --record-golden, etc.
# Quote the whole thing if it contains spaces.
SEQ_EXTRA_ARGS=
